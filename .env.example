# Host port 3307 is used to avoid clashing with any native MySQL on 3306.
DATABASE_URL="mysql://user:password@localhost:3307/gridbase-api"
PORT=4000
NODE_ENV=development
API_VERSION=v1
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=3600000
# Bearer token for write endpoints (POST /transfers). Leave unset to keep the
# API read-only; set a strong secret to enable the admin transfer feed.
# Generate one with: openssl rand -hex 32
# ADMIN_TOKEN="change-me-to-a-long-random-secret"

# Transfer cron — derives transfers from the grids on a schedule and pushes them
# live. Off by default. TRANSFER_SYNC_CRON is a standard cron expression.
ENABLE_TRANSFER_CRON=false
TRANSFER_SYNC_CRON="0 */6 * * *"

# Allowed browser origins for CORS (comma-separated). Leave unset to allow any
# origin in development; set your front-end domain(s) in production.
# CORS_ORIGIN="https://pitwall.app,https://www.pitwall.app"
